<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <EditText
        android:id="@+id/etIdPelanggan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ID Pelanggan untuk Cek Koneksi"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnCekKoneksi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cek Status Perangkat"
        app:layout_constraintTop_toBottomOf="@+id/etIdPelanggan"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status Koneksi: Menunggu Pengecekan"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/btnCekKoneksi"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btnRestart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Restart Perangkat Jarak Jauh"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/tvStatus"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btnTiketTeknisi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buat Tiket Fisik ke Teknisi"
        android:visibility="gone"
        android:backgroundTint="#F44336"
        app:layout_constraintTop_toBottomOf="@+id/btnRestart"
        android:layout_marginTop="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>