<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Buat Tiket Keluhan"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Kolom Pencarian Pintar -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPelanggan"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        android:hint="Cari Pelanggan (Ketik Nama / ID)">

        <AutoCompleteTextView
            android:id="@+id/etPelanggan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:completionThreshold="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <EditText
        android:id="@+id/etKategori"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Kategori (contoh: Jaringan Lemot / Tagihan)"
        app:layout_constraintTop_toBottomOf="@+id/tilPelanggan"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/etKeluhan"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:hint="Deskripsikan detail keluhan pelanggan..."
        android:gravity="top|start"
        android:inputType="textMultiLine"
        app:layout_constraintTop_toBottomOf="@+id/etKategori"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btnKirimTiket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kirim Tiket Keluhan"
        app:layout_constraintTop_toBottomOf="@+id/etKeluhan"
        android:layout_marginTop="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>