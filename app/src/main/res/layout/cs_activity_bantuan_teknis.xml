<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Bantuan Teknis &amp; Pemantauan"
        android:textColor="#1A1C1E"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Lakukan diagnosis jaringan dan kendali perangkat modem jarak jauh."
        android:textColor="#6C757D"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_end_toEndOf="parent">

        <ImageView
            android:id="@+id/ivSearchIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_blue_approval_container"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_search"
            app:layout_constraintBottom_toBottomOf="@id/tilPelanggan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tilPelanggan"
            app:layout_constraintVertical_bias="0.266"
            app:tint="#1E88E5" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPelanggan"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:hint="Cari Pelanggan (Ketik Nama / ID)"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:layout_end_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivSearchIcon"
            app:layout_constraintTop_toTopOf="parent">

            <AutoCompleteTextView
                android:id="@+id/etPelanggan"
                android:layout_width="304dp"
                android:layout_height="29dp"
                android:completionThreshold="1"
                android:inputType="text"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCekKoneksi"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="16dp"
        android:text="Cek Status Perangkat"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#1E88E5"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutSearchContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_end_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="visible"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@+id/btnCekKoneksi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_end_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasil Diagnosis Sistem:"
                android:textColor="#757575"
                android:textSize="13sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Menunggu Perintah..."
                android:textColor="#1A1C1E"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRestart"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="20dp"
        android:visibility="visible"
        android:text="Restart Perangkat Jarak Jauh"
        android:textAllCaps="false"
        android:textColor="#1E88E5"
        android:textSize="14sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="#1E88E5"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@+id/layoutStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_end_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/layoutAksiAkhirContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:weightSum="2"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@+id/btnRestart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_end_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTutupLaporan"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Tutup Laporan"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTiketTeknisi"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Buat Tiket Fisik"
            android:textAllCaps="false"
            android:textSize="13sp"
            android:textStyle="bold"
            android:backgroundTint="#F44336"
            app:cornerRadius="10dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>