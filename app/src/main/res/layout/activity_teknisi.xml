<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".CekOdpActivity">

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard Teknisi"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tvSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Silakan pilih menu operasional di bawah ini:"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnMenuOdp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🔍  Cek Ketersediaan Jaringan (ODP)"
        android:gravity="start|center_vertical"
        android:paddingStart="20dp"
        app:layout_constraintTop_toBottomOf="@+id/tvSub"
        android:layout_marginTop="40dp" />

    <Button
        android:id="@+id/btnMenuMintaBarang"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="📦  Form Permintaan Perangkat"
        android:gravity="start|center_vertical"
        android:paddingStart="20dp"
        app:layout_constraintTop_toBottomOf="@+id/btnMenuOdp"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btnMenuInstalasi"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="✅  Detail Tiket &amp; Selesai Instalasi"
        android:gravity="start|center_vertical"
        android:paddingStart="20dp"
        app:layout_constraintTop_toBottomOf="@+id/btnMenuMintaBarang"
        android:layout_marginTop="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>